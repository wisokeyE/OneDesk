<ui:FluentWindow
    x:Class="OneDesk.Views.Windows.PermissionManagerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:models="clr-namespace:OneDesk.Models.Permissions"
    Title="权限管理"
    Width="640"
    Height="600"
    ExtendsContentIntoTitleBar="True"
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="权限管理" Grid.Row="0" Height="32"/>

        <ui:DynamicScrollViewer Grid.Row="1">
            <StackPanel Margin="24,12,24,24">

                <!-- 文件名标题 -->
                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16,12" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Shield24" FontSize="24"
                                       Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                       Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Text="权限管理" FontSize="16" FontWeight="SemiBold"/>
                            <ui:TextBlock Text="{Binding ItemName}" Appearance="Secondary" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 新增权限 -->
                <ui:TextBlock Text="添加用户权限" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        PlaceholderText="输入用户邮箱地址"
                                        Text="{Binding InviteEmail, UpdateSourceTrigger=PropertyChanged}"
                                        Margin="0,0,8,0"/>
                            <ui:Button Grid.Column="1"
                                       Content="添加"
                                       Appearance="Primary"
                                       Command="{Binding InviteUserCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <ui:TextBlock Text="权限：" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <RadioButton Content="可编辑"
                                         IsChecked="{Binding SelectedRole, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=write}"
                                         Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <RadioButton Content="可查看"
                                         IsChecked="{Binding SelectedRole, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=read}"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 当前权限列表标题 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Text="当前权限" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ui:Button Grid.Column="1"
                               Content="刷新"
                               Command="{Binding LoadPermissionsCommand}">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                </Grid>

                <!-- 加载指示器 -->
                <ProgressBar IsIndeterminate="True"
                             Margin="0,0,0,8"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- 权限列表 -->
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="0" Margin="0,0,0,12">
                    <ItemsControl ItemsSource="{Binding Permissions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:PermissionItem}">
                                <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 用户图标 -->
                                        <Border Grid.Column="0"
                                                Width="36" Height="36"
                                                CornerRadius="18"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                Margin="0,0,12,0">
                                            <ui:Image CornerRadius="30" Source="{Binding PhotoBitmap, FallbackValue={x:Null}}" />
                                        </Border>

                                        <!-- 用户名和邮箱 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <ui:TextBlock Text="{Binding DisplayName}" FontWeight="Medium"/>
                                            <ui:TextBlock Text="{Binding Email}" Appearance="Secondary" FontSize="12"/>
                                        </StackPanel>

                                        <!-- 角色标签 -->
                                        <Border Grid.Column="2"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="4" Padding="8,3"
                                                Margin="8,0" VerticalAlignment="Center">
                                            <ui:TextBlock Text="{Binding RolesDisplay}" FontSize="12"/>
                                        </Border>

                                        <!-- 删除按钮 -->
                                        <ui:Button Grid.Column="3"
                                                   VerticalAlignment="Center"
                                                   Appearance="Secondary"
                                                   Command="{Binding DataContext.DeletePermissionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                   CommandParameter="{Binding}">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOwner}" Value="True">
                                                            <Setter Property="Visibility" Value="Hidden"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                            <ui:SymbolIcon Symbol="Delete24"/>
                                        </ui:Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- 状态消息 -->
                <ui:InfoBar IsOpen="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToBoolConverter}}"
                            Message="{Binding StatusMessage}"
                            IsClosable="False"
                            Severity="Informational"/>
            </StackPanel>
        </ui:DynamicScrollViewer>
    </Grid>
</ui:FluentWindow>
