<Application
    x:Class="OneDesk.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:OneDesk.Helpers.Converters"
    DispatcherUnhandledException="OnDispatcherUnhandledException"
    Exit="OnExit"
    Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <converters:FileSizeConverter x:Key="FileSizeConverter" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <!-- Null 到 Visibility 转换器 -->
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <!-- 反向 Null 到 Visibility 转换器（null 时显示，非 null 时隐藏） -->
            <converters:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" />
            <converters:StringNotEmptyToBoolConverter x:Key="StringNotEmptyToBoolConverter" />
            <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
